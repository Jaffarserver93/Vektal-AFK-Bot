modules = ["nodejs-20", "bash", "web"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AFK Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "LinkPays Probe"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "LinkPays Deep Probe"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "LinkPays Full Flow"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Earn Form Probe"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "LinkPays Complete Probe"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "LinkPays Bypasser"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "LinkPays Runner"

[[workflows.workflow]]
name = "AFK Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PATH=/nix/store/sx3d9r61bi7xpg1vjiyvbay99634i282-xorg-server-21.1.18/bin:$PATH pnpm --filter @workspace/scripts run afk-bot"

[[workflows.workflow]]
name = "LinkPays Probe"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PATH=/nix/store/sx3d9r61bi7xpg1vjiyvbay99634i282-xorg-server-21.1.18/bin:$PATH pnpm --filter @workspace/scripts run linkpays-probe"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "LinkPays Deep Probe"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PATH=/nix/store/sx3d9r61bi7xpg1vjiyvbay99634i282-xorg-server-21.1.18/bin:$PATH pnpm --filter @workspace/scripts run linkpays-deep-probe 2>&1 | tee /tmp/deep-probe-report.txt"

[[workflows.workflow]]
name = "LinkPays Full Flow"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PATH=/nix/store/sx3d9r61bi7xpg1vjiyvbay99634i282-xorg-server-21.1.18/bin:$PATH pnpm --filter @workspace/scripts run linkpays-full-flow 2>&1 | tee /tmp/full-flow-report.txt"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Earn Form Probe"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PATH=/nix/store/sx3d9r61bi7xpg1vjiyvbay99634i282-xorg-server-21.1.18/bin:$PATH pnpm --filter @workspace/scripts run earn-form-probe 2>&1 | tee /tmp/earn-form-probe.txt"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "LinkPays Complete Probe"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PATH=/nix/store/sx3d9r61bi7xpg1vjiyvbay99634i282-xorg-server-21.1.18/bin:$PATH pnpm --filter @workspace/scripts run linkpays-complete-probe 2>&1 | tee /tmp/complete-probe.txt"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "LinkPays Bypasser"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PATH=/nix/store/sx3d9r61bi7xpg1vjiyvbay99634i282-xorg-server-21.1.18/bin:$PATH pnpm --filter @workspace/scripts run linkpays-bypasser 2>&1 | tee /tmp/bypasser.txt"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "LinkPays Runner"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PATH=/nix/store/sx3d9r61bi7xpg1vjiyvbay99634i282-xorg-server-21.1.18/bin:$PATH pnpm --filter @workspace/scripts run linkpays-runner 2>&1 | tee /tmp/linkpays-runner.txt"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 10000
externalPort = 9000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "5000"
