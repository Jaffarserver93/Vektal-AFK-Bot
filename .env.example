# ── Required ──────────────────────────────────────────────────────────────────
# Your vektalnodes.in login credentials
VEKTAL_EMAIL=you@example.com
VEKTAL_PASSWORD=yourpassword

# ── Port (Ubuntu / local) ─────────────────────────────────────────────────────
# Health-check server port. Pick any free port on your machine.
PORT=10000

# ── Chromium / Xvfb paths ─────────────────────────────────────────────────────
# start.sh auto-detects these on Ubuntu — only set if detection fails.
# CHROMIUM_PATH=/usr/bin/chromium-browser
# XVFB_PATH=/usr/bin/Xvfb

# ── Already set by start.sh / Dockerfile — leave commented unless overriding ──
# PUPPETEER_SKIP_DOWNLOAD=true
# NODE_ENV=production

# ── Optional ──────────────────────────────────────────────────────────────────
# DATABASE_URL=postgres://...   ← only needed if you add DB logging later
