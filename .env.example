# ── Required ──────────────────────────────────────────────────────────────────
# Your vektalnodes.in login credentials
VEKTAL_EMAIL=you@example.com
VEKTAL_PASSWORD=yourpassword

# ── Already set in Dockerfile (do NOT override on Render unless you know why) ─
# CHROMIUM_PATH=/usr/bin/chromium   ← system Chromium installed by apt
# XVFB_PATH=/usr/bin/Xvfb           ← virtual display for headless Chrome
# PUPPETEER_SKIP_DOWNLOAD=true       ← don't download bundled Chromium
# NODE_ENV=production

# ── Optional / not currently used by the runner ───────────────────────────────
# DATABASE_URL=postgres://...        ← only needed if you add DB logging later
